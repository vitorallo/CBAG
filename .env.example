# CBAG configuration — copy to .env and adjust as needed.
# docker-compose reads this file automatically for variable substitution.

# Base CUDA image for the GPU model services. Must be compatible with the GB10's
# driver/CUDA (confirmed: driver 580.x, CUDA 13.0 -> CUDA 13 base image).
CBAG_CUDA_BASE=nvidia/cuda:13.0.1-base-ubuntu24.04

# Backend
BACKEND_PORT=8000

# --- LLM (Ollama) ---
# Two modes:
#   A) Reuse an existing host Ollama (default; what this GB10 uses):
#        LLM_BASE_URL=http://host.docker.internal:11434
#        start with: ./scripts/up.sh
#   B) Bundled Ollama for a fresh box with no Ollama installed:
#        LLM_BASE_URL=http://llm:11434
#        start with: ./scripts/up.sh --bundled-llm
LLM_BASE_URL=http://host.docker.internal:11434

# Ollama model for stage-2 text refinement only (voice/video use separate models).
# Default is a small, fast, Apache-2.0 instruct model; scripts/fetch-models.sh pulls
# it. Use a bigger model (e.g. gpt-oss:20b) for richer prose if your box can spare it.
CBAG_LLM_MODEL=qwen2.5:3b

# tts/video use compose DNS names for in-cluster calls.
# For an external client (e.g. the Mac webapp), point these at the GB10 IP.
TTS_BASE_URL=http://tts:8100
VIDEO_BASE_URL=http://video:8200

# Shared artifact storage path inside containers
ARTIFACT_ROOT=/artifacts

# --- HTTPS edge (Caddy) ---
# scripts/build.sh auto-detects these; set them only to override.
# CBAG_HOST: the address you reach the app on (printed in URLs).
# CBAG_SANS: cert Subject Alternative Names (every IP/host you reach the box on).
# CBAG_HTTPS_PORT: host port for HTTPS (443 is often taken by the Dell demo -> 8443).
CBAG_HOST=localhost
CBAG_SANS=DNS:localhost,IP:127.0.0.1
CBAG_HTTPS_PORT=8443
